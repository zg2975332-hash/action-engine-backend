# AetherFlow Backend Configuration
# This project uses Google Vertex AI (not direct Gemini API)

# ============================================
# VERTEX AI CONFIGURATION (REQUIRED)
# ============================================

# Enable Vertex AI mode
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Your Google Cloud Project ID
# Get from: https://console.cloud.google.com/
GOOGLE_CLOUD_PROJECT=your-project-id-here

# Vertex AI location/region
# Common options: us-central1, us-east1, europe-west1, asia-southeast1
GOOGLE_CLOUD_LOCATION=us-central1

# ============================================
# MODEL CONFIGURATION
# ============================================

# Gemini model to use
# Options:
#   - gemini-2.5-flash (recommended, fastest)
#   - gemini-2.0-flash-exp
#   - gemini-1.5-pro
#   - gemini-1.5-flash
MODEL_NAME=gemini-2.5-flash

# ============================================
# NOTES FOR GOOGLE ANTIGRAVITY IDE USERS
# ============================================
# If you're using Google Antigravity IDE, these values are
# automatically configured. You don't need to change anything!

# ============================================
# NOTES FOR MANUAL SETUP
# ============================================
# 1. Create a Google Cloud Project
# 2. Enable Vertex AI API
# 3. Run: gcloud auth application-default login
# 4. Replace "your-project-id-here" with your actual project ID
# 5. Keep this file secure - do NOT commit .env to Git

